{
  "name": "@iml1s/oh-my-cursor",
  "version": "0.2.1",
  "description": "A capability-grounded orchestration foundation for Cursor Agent",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./host": {
      "types": "./dist/src/host/cursor-agent.d.ts",
      "import": "./dist/src/host/cursor-agent.js"
    },
    "./capabilities": {
      "types": "./dist/src/capabilities/discovery.d.ts",
      "import": "./dist/src/capabilities/discovery.js"
    },
    "./sessions": {
      "types": "./dist/src/sessions/router.d.ts",
      "import": "./dist/src/sessions/router.js"
    },
    "./runtime": {
      "types": "./dist/src/runtime/state-root.d.ts",
      "import": "./dist/src/runtime/state-root.js"
    },
    "./setup": { "types": "./dist/src/setup/index.d.ts", "import": "./dist/src/setup/index.js" },
    "./recovery": { "types": "./dist/src/recovery/index.d.ts", "import": "./dist/src/recovery/index.js" },
    "./compaction": { "types": "./dist/src/compaction/index.d.ts", "import": "./dist/src/compaction/index.js" },
    "./memory": { "types": "./dist/src/memory/index.d.ts", "import": "./dist/src/memory/index.js" },
    "./notify": { "types": "./dist/src/notify/index.d.ts", "import": "./dist/src/notify/index.js" },
    "./tracker": { "types": "./dist/src/tracker/index.d.ts", "import": "./dist/src/tracker/index.js" },
    "./wiki": { "types": "./dist/src/wiki/index.d.ts", "import": "./dist/src/wiki/index.js" },
    "./mcp": { "types": "./dist/src/mcp/index.d.ts", "import": "./dist/src/mcp/index.js" },
    "./workflows": { "types": "./dist/src/workflows/index.d.ts", "import": "./dist/src/workflows/index.js" },
    "./modes": { "types": "./dist/src/modes/index.d.ts", "import": "./dist/src/modes/index.js" },
    "./team": { "types": "./dist/src/team/index.d.ts", "import": "./dist/src/team/index.js" },
    "./package.json": "./package.json"
  },
  "bin": {
    "omcu": "./dist/bin/omcu.js"
  },
  "files": [
    "dist",
    ".cursor-plugin",
    ".cursor/rules",
    ".mcp.json",
    "agents",
    "commands",
    "hooks",
    "skills",
    "templates",
    "scripts/install.sh",
    "scripts/install-plugin.sh",
    "scripts/uninstall.sh",
    "omcu_capabilities.lock.json",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "PROJECT.md",
    "TEST_READY.md",
    "docs",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/clean.mjs && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cli": "vitest run tests/cli.test.ts tests/cli-integration.test.ts",
    "smoke": "node ./scripts/smoke.mjs",
    "parity": "node ./scripts/parity-check.mjs",
    "package:dry-run": "npm pack --dry-run --json",
    "release:archive": "node ./scripts/release-archive.mjs",
    "check": "npm run build && npm test && npm run smoke && npm run parity"
  },
  "engines": { "node": ">=20" },
  "license": "MIT",
  "keywords": ["cursor", "cursor-agent", "orchestration", "cli"] ,
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
